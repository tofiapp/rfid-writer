<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingEnd="8dp"
    android:paddingTop="7dp"
    android:paddingBottom="6dp">

    <!-- Row: seq | ID_RFID | time | dup | delete -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvItemSeq"
            android:layout_width="22dp"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="9sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvItemNum"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#d2a8ff"
            android:textStyle="bold"
            android:textSize="15sp"
            android:fontFamily="monospace"/>

        <TextView
            android:id="@+id/tvItemTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#666666"
            android:textSize="9sp"
            android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/tvItemDup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#f85149"
            android:textSize="9sp"
            android:textStyle="bold"
            android:layout_marginEnd="2dp"/>

        <Button
            android:id="@+id/btnItemDel"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="✕"
            android:textSize="11sp"
            android:textColor="#888888"
            android:backgroundTint="#2A2A2A"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"/>

    </LinearLayout>

    <!-- EPC row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="22dp"
        android:paddingTop="3dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:text="EPC"
            android:textColor="#888888"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

        <TextView
            android:id="@+id/tvItemEpc"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#00BCD4"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"/>

    </LinearLayout>

    <!-- TID row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="22dp"
        android:paddingTop="2dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:text="TID"
            android:textColor="#888888"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"/>

        <TextView
            android:id="@+id/tvItemTid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#4CAF50"
            android:fontFamily="monospace"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"/>

    </LinearLayout>

</LinearLayout>
