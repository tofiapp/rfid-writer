<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- ── Global header ─────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#1A1A1A"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="RFID Writer"
            android:textColor="#E0E0E0"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● Inicializace..."
            android:textColor="#FF9800"
            android:textSize="12sp"/>

    </LinearLayout>

    <!-- ── Tab bar ────────────────────────────────────────────────────────── -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A1A1A"
        app:tabTextColor="#888888"
        app:tabSelectedTextColor="#00BCD4"
        app:tabIndicatorColor="#00BCD4"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabTextAppearance="@android:style/TextAppearance.Small">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TAGY"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZÁPIS EPC"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SKUPINOVÝ"/>

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZAMČENÍ"/>

    </com.google.android.material.tabs.TabLayout>

    <!-- ── Tab content ────────────────────────────────────────────────────── -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ══════════════════════════════════════════════════════════════════
             PAGE 0 — Načítání tagů
             ══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/pageTag"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="visible">

            <Button
                android:id="@+id/btnScan"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="📡  SKENOVAT TAG"
                android:textSize="16sp"
                android:textColor="#121212"
                android:backgroundTint="#00BCD4"
                android:layout_marginBottom="12dp"
                android:enabled="false"/>

            <!-- EPC / TID card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#1E1E1E"
                android:padding="12dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AKTUÁLNÍ EPC"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvCurrentEpc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#00BCD4"
                    android:textSize="18sp"
                    android:fontFamily="monospace"
                    android:paddingTop="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TID"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:paddingTop="8dp"/>

                <TextView
                    android:id="@+id/tvTid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#888888"
                    android:textSize="13sp"
                    android:fontFamily="monospace"
                    android:paddingTop="2dp"/>

            </LinearLayout>

            <!-- Log console -->
            <ScrollView
                android:id="@+id/scrollLog"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#0D0D0D">

                <TextView
                    android:id="@+id/tvLog"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#00FF88"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:padding="8dp"/>

            </ScrollView>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════════
             PAGE 1 — Zápis EPC
             ══════════════════════════════════════════════════════════════ -->
        <ScrollView
            android:id="@+id/pageWriteEpc"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Bank / Prt / Len -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="12dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PARAMETRY"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:paddingBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Bank (fixed: EPC) -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bank"
                                android:textColor="#888888"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="EPC"
                                android:textColor="#00BCD4"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:fontFamily="monospace"
                                android:paddingTop="6dp"/>

                        </LinearLayout>

                        <!-- Prt -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Prt"
                                android:textColor="#888888"
                                android:textSize="11sp"/>

                            <EditText
                                android:id="@+id/etWritePrt"
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:text="2"
                                android:textColor="#E0E0E0"
                                android:textSize="18sp"
                                android:fontFamily="monospace"
                                android:inputType="number"
                                android:background="@null"
                                android:paddingTop="4dp"/>

                        </LinearLayout>

                        <!-- Len -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Len"
                                android:textColor="#888888"
                                android:textSize="11sp"/>

                            <EditText
                                android:id="@+id/etWriteLen"
                                android:layout_width="56dp"
                                android:layout_height="wrap_content"
                                android:text="6"
                                android:textColor="#E0E0E0"
                                android:textSize="18sp"
                                android:fontFamily="monospace"
                                android:inputType="number"
                                android:background="@null"
                                android:paddingTop="4dp"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Access Password -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="12dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACCESS PWD"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>

                    <EditText
                        android:id="@+id/etWriteAccessPwd"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="00000000"
                        android:textColorHint="#555555"
                        android:textColor="#E0E0E0"
                        android:textSize="18sp"
                        android:fontFamily="monospace"
                        android:inputType="textNoSuggestions|textCapCharacters"
                        android:background="@null"
                        android:paddingTop="8dp"
                        android:maxLength="8"/>

                </LinearLayout>

                <!-- New EPC -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="12dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NEW EPC"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>

                    <EditText
                        android:id="@+id/etNewEpc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="např. E28011700000020F33A81001"
                        android:textColorHint="#555555"
                        android:textColor="#E0E0E0"
                        android:textSize="16sp"
                        android:fontFamily="monospace"
                        android:inputType="textNoSuggestions|textCapCharacters"
                        android:background="@null"
                        android:paddingTop="8dp"
                        android:maxLines="2"/>

                </LinearLayout>

                <!-- Write button -->
                <Button
                    android:id="@+id/btnWrite"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="✏️  WRITE"
                    android:textSize="16sp"
                    android:textColor="#121212"
                    android:backgroundTint="#4CAF50"/>

            </LinearLayout>

        </ScrollView>

        <!-- ══════════════════════════════════════════════════════════════════
             PAGE 2 — Skupinový zápis (placeholder)
             ══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/pageGroupWrite"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Připravuje se…"
                android:textColor="#555555"
                android:textSize="16sp"/>

        </LinearLayout>

        <!-- ══════════════════════════════════════════════════════════════════
             PAGE 3 — Uzamčení
             ══════════════════════════════════════════════════════════════ -->
        <ScrollView
            android:id="@+id/pageLock"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ── Section: Zápis hesla ──────────────────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ZÁPIS HESLA"
                    android:textColor="#00BCD4"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:paddingBottom="10dp"/>

                <!-- Bank / Prt / Len (Reserved, 2, 2) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="12dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PARAMETRY"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:paddingBottom="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bank"
                                android:textColor="#888888"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reserved"
                                android:textColor="#00BCD4"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="monospace"
                                android:paddingTop="6dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Prt"
                                android:textColor="#888888"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2"
                                android:textColor="#E0E0E0"
                                android:textSize="18sp"
                                android:fontFamily="monospace"
                                android:paddingTop="4dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:paddingStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Len"
                                android:textColor="#888888"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2"
                                android:textColor="#E0E0E0"
                                android:textSize="18sp"
                                android:fontFamily="monospace"
                                android:paddingTop="4dp"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!-- Access Pwd (stávající) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="12dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACCESS PWD"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>

                    <EditText
                        android:id="@+id/etPwdCurrentPwd"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="00000000"
                        android:textColorHint="#555555"
                        android:textColor="#E0E0E0"
                        android:textSize="18sp"
                        android:fontFamily="monospace"
                        android:inputType="textNoSuggestions|textCapCharacters"
                        android:background="@null"
                        android:paddingTop="8dp"
                        android:maxLength="8"/>

                </LinearLayout>

                <!-- New Pwd -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="12dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NEW PWD"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>

                    <EditText
                        android:id="@+id/etPwdNewPwd"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint=""
                        android:textColorHint="#555555"
                        android:textColor="#E0E0E0"
                        android:textSize="18sp"
                        android:fontFamily="monospace"
                        android:inputType="textNoSuggestions|textCapCharacters"
                        android:background="@null"
                        android:paddingTop="8dp"
                        android:maxLength="8"/>

                </LinearLayout>

                <!-- Write button (heslo) -->
                <Button
                    android:id="@+id/btnWritePwd"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="✏️  WRITE"
                    android:textSize="16sp"
                    android:textColor="#121212"
                    android:backgroundTint="#4CAF50"
                    android:layout_marginBottom="20dp"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#2E2E2E"
                    android:layout_marginBottom="20dp"/>

                <!-- ── Section: Zamčení ───────────────────────────────────── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ZAMČENÍ"
                    android:textColor="#00BCD4"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.15"
                    android:paddingBottom="10dp"/>

                <!-- Access Pwd (nové) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="12dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ACCESS PWD"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>

                    <EditText
                        android:id="@+id/etLockAccessPwd"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="00000000"
                        android:textColorHint="#555555"
                        android:textColor="#E0E0E0"
                        android:textSize="18sp"
                        android:fontFamily="monospace"
                        android:inputType="textNoSuggestions|textCapCharacters"
                        android:background="@null"
                        android:paddingTop="8dp"
                        android:maxLength="8"/>

                </LinearLayout>

                <!-- Lock kód -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="#1E1E1E"
                    android:padding="12dp"
                    android:layout_marginBottom="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LOCK KÓD"
                        android:textColor="#888888"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"/>

                    <EditText
                        android:id="@+id/etLockCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="008020"
                        android:textColor="#E0E0E0"
                        android:textSize="18sp"
                        android:fontFamily="monospace"
                        android:inputType="textNoSuggestions|textCapCharacters"
                        android:background="@null"
                        android:paddingTop="8dp"
                        android:maxLength="8"/>

                </LinearLayout>

                <!-- Lock button -->
                <Button
                    android:id="@+id/btnLock"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="🔒  LOCK"
                    android:textSize="16sp"
                    android:textColor="#121212"
                    android:backgroundTint="#FF9800"
                    android:layout_marginBottom="16dp"/>

            </LinearLayout>

        </ScrollView>

    </FrameLayout>

</LinearLayout>
