<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="RFID Writer"
        android:textColor="#E0E0E0"
        android:textSize="24sp"
        android:textStyle="bold"
        android:paddingBottom="4dp"/>

    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="● Inicializace..."
        android:textColor="#FF9800"
        android:textSize="13sp"
        android:paddingBottom="16dp"/>

    <!-- Scan button -->
    <Button
        android:id="@+id/btnScan"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📡  SKENOVAT TAG"
        android:textSize="16sp"
        android:textColor="#121212"
        android:backgroundTint="#00BCD4"
        android:layout_marginBottom="16dp"/>

    <!-- Current EPC card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E1E1E"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AKTUÁLNÍ EPC"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.1"/>

        <TextView
            android:id="@+id/tvCurrentEpc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#00BCD4"
            android:textSize="18sp"
            android:fontFamily="monospace"
            android:paddingTop="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TID"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.1"
            android:paddingTop="8dp"/>

        <TextView
            android:id="@+id/tvTid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#888888"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:paddingTop="2dp"/>
    </LinearLayout>

    <!-- New EPC input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E1E1E"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOVÝ EPC (hex, bez mezer)"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.1"/>

        <EditText
            android:id="@+id/etNewEpc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="např. E28011700000020F33A81001"
            android:textColorHint="#555555"
            android:textColor="#E0E0E0"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:inputType="textNoSuggestions"
            android:background="@null"
            android:paddingTop="8dp"
            android:maxLines="2"/>

        <Button
            android:id="@+id/btnWrite"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="✏️  ZAPSAT EPC"
            android:textColor="#121212"
            android:backgroundTint="#4CAF50"
            android:layout_marginTop="10dp"
            android:enabled="false"/>
    </LinearLayout>

    <!-- Password / Lock card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E1E1E"
        android:padding="12dp"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZAHESLOVÁNÍ TAGU"
            android:textColor="#888888"
            android:textSize="11sp"
            android:letterSpacing="0.1"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Access password (8 hex znaků, prázdné = 00000000)"
            android:textColorHint="#555555"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:inputType="textNoSuggestions"
            android:background="@null"
            android:paddingTop="8dp"
            android:maxLength="8"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/btnLockEpc"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🔒 Lock EPC"
                android:textColor="#121212"
                android:backgroundTint="#FF9800"
                android:layout_marginEnd="6dp"
                android:enabled="false"/>

            <Button
                android:id="@+id/btnLockAll"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="🔐 Lock ALL"
                android:textColor="#121212"
                android:backgroundTint="#F44336"
                android:layout_marginStart="6dp"
                android:enabled="false"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Log output -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0D0D0D">

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#00FF88"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="8dp"/>
    </ScrollView>

</LinearLayout>
